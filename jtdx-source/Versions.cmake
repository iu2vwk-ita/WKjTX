# Version number components
# WKjTX versioning is independent from upstream JTDX (originally 2.2.159).
# v1.1.1 adds Day/Night quick toggle in Tema menu, fixes tab-bar text
# truncation in non-default themes, fixes amber theme switching, adds
# date-filtered ADIF export (Since-last / Last-7 / Last-30 / custom range).
set (WSJTX_VERSION_MAJOR 1)
set (WSJTX_VERSION_MINOR 1)
set (WSJTX_VERSION_32A 1)
set (WSJTX_VERSION_SUB 0)
set (WSJTX_RC 0)		 # release candidate number, comment out or zero for development versions
set (WSJTX_VERSION_IS_RELEASE 1) # set to 1 for final release build
